# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com

# Your Supabase project URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous key (found in Project Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI Enrichment Configuration

# OpenAI API Key - For AI-powered data enrichment
# Get your API key at https://platform.openai.com/api-keys
# This enables automatic data enrichment, value proposition generation, and more
OPENAI_API_KEY=sk-your-openai-api-key-here

# Web Scraping Configuration (Optional)

# ScraperAPI Key - For bypassing anti-bot protection (444 errors)
# Get free API key (1,000 requests/month) at https://www.scraperapi.com
# Uncomment and add your key to use:
# SCRAPER_API_KEY=your-scraper-api-key-here

# Instructions:
# 1. Copy this file and rename it to .env.local
# 2. Go to https://app.supabase.com
# 3. Select your project (or create one if you haven't)
# 4. Go to Project Settings > API
# 5. Copy the "Project URL" and paste it as NEXT_PUBLIC_SUPABASE_URL
# 6. Copy the "anon public" key and paste it as NEXT_PUBLIC_SUPABASE_ANON_KEY
# 7. Go to https://platform.openai.com/api-keys and create an API key
# 8. Copy the OpenAI API key and paste it as OPENAI_API_KEY
# 9. (Optional) Sign up for ScraperAPI and add SCRAPER_API_KEY for better scraping
# 10. Save this file
# 11. Restart your dev server (npm run dev)
